{% endblock %}
{%- else -%}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>aesv.io</title>
  <meta name="description" content="Axel Stevens — systems integrator. Work, writing, listening.">
  <link rel="icon" href="/logo-pixel.png" type="image/png">
  <link rel="apple-touch-icon" href="/logo.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#F4ECD8">
  <link rel="preload" href="/fonts/birdie-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="dashboard">
    {% include "partials/site-header.njk" %}

    <div class="dashboard-grid">
      {# Top row: weather · about · work #}
      <div class="widget-cell weather widget-cell-bare">
        {% include "partials/widgets/weather-ithaca.njk" %}
      </div>

      <a class="tile tile-link about" href="/about">
        <span class="tile-label">about <span class="tile-label-arrow" aria-hidden="true">↗</span></span>
      </a>

      <a class="tile tile-link work tile-primary" href="/work">
        <span class="tile-label">work <span class="tile-label-arrow" aria-hidden="true">↗</span></span>
      </a>

      {# Bottom row: music · activities (chess + strava cycle) · files #}
      <a class="widget-cell spotify widget-cell-link" href="/music" aria-label="Open the music page">
        {% include "partials/widgets/spotify-album.njk" %}
        <span class="cell-hover-label">music <span class="tile-label-arrow" aria-hidden="true">↗</span></span>
      </a>

      <a class="widget-cell hobbies widget-cell-link" href="/activities" aria-label="Activities — chess and Strava">
        {% include "partials/widgets/hobbies-cycle.njk" %}
        <span class="cell-hover-label">activities <span class="tile-label-arrow" aria-hidden="true">↗</span></span>
      </a>

      <a class="tile tile-link grdn" href="/garden">
        <span class="tile-label">files <span class="tile-label-arrow" aria-hidden="true">↗</span></span>
      </a>
    </div>

    <script src="/js/dashboard.js"></script>
  </main>

  {% include "partials/big-footer.njk" %}
</body>
</html>
{%- endif -%}
