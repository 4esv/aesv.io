{% extends "base-pretext.njk" %}
{% block title %}{{ site.name }}{% endblock %}

{% block content %}

{# ── Hero ─────────────────────────────────────────────────────────────── #}
<header id="hero">
  {# NOTE: AsciiMotif renders ·>· as variable-weight ASCII art via pretext #}
  <canvas id="motif-canvas" aria-hidden="true"></canvas>
  <p class="hero-meta">
    Mexican-American creator and curator of software, music, food, and information.
    This is my corner of the internet and public page. Feel free to look around.
  </p>
</header>

{# ── About ────────────────────────────────────────────────────────────── #}
<section id="about" class="pt-section">
  <div class="pt-label">about</div>
  <p>
    I specialize in extending, automating and creating software —
    everything from AI integrations to full-stack applications.
    Like my text editor, I work across all operating systems via the command line.
  </p>
  <p style="margin-top: 0.7em">
    Interested in remote projects and opportunities.
    <a href="mailto:mail@aesv.io">mail@aesv.io ↗</a>
  </p>
</section>

{# ── Work ─────────────────────────────────────────────────────────────── #}
<section id="work" class="pt-section">
  <div class="pt-label">work</div>

  <div class="pt-accordion" data-open="false">
    <div class="pt-accordion-header">
      Systems Integrator · <span class="muted">Cornell University</span>
    </div>
    <div class="pt-accordion-body">
      <p class="pt-accordion-meta">Building internal applications, automations and supporting software.</p>
      <div class="pt-chips">
        <span class="pt-chip pt-chip--role">full-time</span>
        <span class="pt-chip pt-chip--tool">Python</span>
        <span class="pt-chip pt-chip--tool">Node.js</span>
        <span class="pt-chip pt-chip--tool">PowerShell</span>
        <span class="pt-chip pt-chip--tool">React</span>
      </div>
    </div>
  </div>

  <div class="pt-accordion" data-open="false">
    <div class="pt-accordion-header">
      Interfolio Dossier Builder
    </div>
    <div class="pt-accordion-body">
      <p>Automated assembly of faculty tenure review packets. Built a full-stack system: React frontend, Node.js/Express API, BullMQ + Redis queue, Python worker with PyPDF2 merge and nested bookmarks.</p>
      <p>Replaced a multi-day manual process with a 5-minute automated run.</p>
      <div class="pt-chips">
        <span class="pt-chip pt-chip--lang">Python</span>
        <span class="pt-chip pt-chip--lang">Node.js</span>
        <span class="pt-chip pt-chip--tool">React</span>
        <span class="pt-chip pt-chip--tool">BullMQ</span>
        <span class="pt-chip pt-chip--tool">Redis</span>
        <span class="pt-chip pt-chip--tool">PyPDF2</span>
        <span class="pt-chip pt-chip--tool">MSSQL</span>
      </div>
    </div>
  </div>

  <div class="pt-accordion" data-open="false">
    <div class="pt-accordion-header">
      Device Asset Sync
    </div>
    <div class="pt-accordion-body">
      <p>Bi-directional sync between Jamf MDM and Snipe-IT in PowerShell. Mac agent with OOP class, exponential backoff, OAuth token refresh, and throttling. Windows agent via Group Policy.</p>
      <p>1,300+ devices at 95%+ accuracy. Eliminated manual inventory entirely.</p>
      <div class="pt-chips">
        <span class="pt-chip pt-chip--lang">PowerShell</span>
        <span class="pt-chip pt-chip--tool">Jamf Pro API</span>
        <span class="pt-chip pt-chip--tool">Snipe-IT API</span>
        <span class="pt-chip pt-chip--tool">Group Policy</span>
      </div>
    </div>
  </div>

  <div class="pt-accordion" data-open="false">
    <div class="pt-accordion-header">
      App Security Manager
    </div>
    <div class="pt-accordion-body">
      <p>RBAC dashboard with three-tier role model (Developer, Owner, Admin). LDAP live search, drag-and-drop user assignment, transactional SQL, Shibboleth/SAML auth. Replaced ColdFusion system in use for over a decade.</p>
      <div class="pt-chips">
        <span class="pt-chip pt-chip--lang">Node.js</span>
        <span class="pt-chip pt-chip--tool">Express</span>
        <span class="pt-chip pt-chip--tool">MSSQL</span>
        <span class="pt-chip pt-chip--tool">LDAP</span>
        <span class="pt-chip pt-chip--tool">Shibboleth/SAML</span>
      </div>
    </div>
  </div>

  <div class="pt-accordion" data-open="false">
    <div class="pt-accordion-header">
      NAO Bot Natural Conversation
    </div>
    <div class="pt-accordion-body">
      <p>Connected NAO's microphone to OpenAI Whisper for transcription, routed through GPT, piped back through NAO's animated speech engine. Proof-of-concept for an NSF grant proposal.</p>
      <div class="pt-chips">
        <span class="pt-chip pt-chip--lang">Python</span>
        <span class="pt-chip pt-chip--tool">NAOqi SDK</span>
        <span class="pt-chip pt-chip--tool">Whisper</span>
        <span class="pt-chip pt-chip--tool">OpenAI API</span>
      </div>
    </div>
  </div>

  <p style="margin-top: 1.4em">
    <a href="https://www.linkedin.com/in/aesv/?skipRedirect=true">linkedin ↗</a>
    · <a href="mailto:mail@aesv.io">mail@aesv.io</a>
  </p>
</section>

{# ── Code ─────────────────────────────────────────────────────────────── #}
<section id="code" class="pt-section">
  <div class="pt-label">code</div>
  <p><a href="https://github.com/4esv/pianito">pianito ↗</a> — TUI piano tuner</p>
  <p><a href="https://github.com/4esv/bbq">bbq ↗</a> — BQN quant toolkit</p>
  <p style="margin-top: 0.7em">
    <a href="https://github.com/4esv/dotfiles">dotfiles ↗</a>
    · <a href="https://github.com/4esv/nvim-config">neovim config ↗</a>
    · <a href="https://github.com/4esv">github ↗</a>
  </p>
</section>

{# ── Music ────────────────────────────────────────────────────────────── #}
<section id="music" class="pt-section">
  <div class="pt-label">music</div>
  <p>Keyboardist, bassist and emergency drummer. I listen to everything from Mexican folklore to Norwegian death metal.</p>

  {% if spotify %}
  <div class="pt-accordion" data-open="false" style="margin-top: 1.4em">
    <div class="pt-accordion-header">top tracks &amp; artists</div>
    <div class="pt-accordion-body">
      <p class="pt-accordion-meta bold">tracks</p>
      {% for track in spotify.tracks %}
      <p><a href="{{ track.url }}">{{ track.name }} ↗</a> <span class="muted">by {{ track.artist }}</span></p>
      {% endfor %}
      <p class="pt-accordion-meta bold" style="margin-top: 0.7em">artists</p>
      {% for artist in spotify.artists %}
      <p><a href="{{ artist.url }}">{{ artist.name }} ↗</a></p>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <p style="margin-top: 1.4em">
    <a href="https://open.spotify.com/user/aesvel">spotify ↗</a>
    · <a href="https://soundcloud.com/4esv">soundcloud ↗</a>
  </p>
</section>

{# ── Chess — dynamic layout: board beside flowing text ────────────────── #}
<section id="chess" class="pt-section">
  <div class="pt-label">chess</div>

  {% if chess %}
  {# NOTE: pt-dynamic-section uses pretext to route text around the board widget #}
  <div class="pt-dynamic-section">
    <div class="pt-dynamic-widget chess-board">
      <span class="muted">{{ chess.white }} vs {{ chess.black }} · {{ chess.result }}</span>
      <code>{% for line in chess.board %}{{ line }}
{% endfor %}</code>
      <a href="{{ chess.url }}">view on chess.com ↗</a>
    </div>
    <div class="pt-dynamic-text" data-content="Last victory on chess.com. {{ chess.white }} played white, {{ chess.black }} played black. Result: {{ chess.result }}.">
      <p>Last victory on chess.com.</p>
      <p class="muted">{{ chess.white }} vs {{ chess.black }} · {{ chess.result }}</p>
      <p><a href="{{ chess.url }}">view on chess.com ↗</a></p>
    </div>
  </div>
  {% else %}
  <p class="muted">no recent victories loaded</p>
  {% endif %}
</section>

{# ── Sport ────────────────────────────────────────────────────────────── #}
<section id="sport" class="pt-section">
  <div class="pt-label">sport</div>
  <p>I walk, climb indoors, run the trails. Sometimes hike the gorges and swim in the lake.</p>

  {% if strava %}
  <div style="margin-top: 1.4em">
    <p class="muted">last activity</p>
    <p>{{ strava.name }}</p>
    <p class="muted">{{ strava.type }} · {{ strava.distance }} mi · {{ strava.duration }} · {{ strava.elevation }} ft gain</p>
  </div>
  {% endif %}

  <p style="margin-top: 1.4em"><a href="https://www.strava.com/athletes/51674641">strava ↗</a></p>
</section>

{% endblock %}
{%- endif -%}
