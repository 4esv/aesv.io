{%- else -%}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>aesv.io</title>
  <meta name="description" content="Axel Stevens — systems integrator. Work, writing, listening.">
  <link rel="icon" href="/logo-pixel.png" type="image/png">
  <link rel="apple-touch-icon" href="/logo.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#F4ECD8">
  <link rel="preload" href="/fonts/birdie-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="dashboard">
    {% include "partials/site-header.njk" %}

    <div class="dashboard-grid">
      {# Top row: weather · music · time #}
      <div class="widget-cell weather widget-cell-bare is-watch-primary">
        {% include "partials/widgets/weather-ithaca.njk" %}
      </div>

      <div class="widget-cell spotify">
        {% include "partials/widgets/spotify-album.njk" %}
      </div>

      <div class="widget-cell time widget-cell-bare">
        {% include "partials/widgets/time-ithaca.njk" %}
      </div>

      {# Bottom row: portfolio · chess · garden #}
      {% set workTags = [
        'react','node','python','powershell','bqn','fastify','vite','mssql',
        'ldap','saml','shibboleth','oauth','redis','bullmq','frevvo','jamf',
        'snipe','interfolio','azure','whisper','gpt','nunjucks','automation',
        'integration','rbac','sso','cron','mdm','cms','devops'
      ] %}
      <a class="tile tile-link work tile-primary" href="/work">
        <div class="tile-cloud" aria-hidden="true">
          {% for tag in workTags %}<span style="--i:{{ loop.index0 }}">{{ tag }}</span>{% endfor %}
        </div>
        <div class="tile-content">
          <div class="tile-desc">Six case studies. Services. Hire me.</div>
          <div class="tile-title">work ↗</div>
        </div>
      </a>

      <a class="widget-cell chess widget-cell-link" href="/chess" aria-label="Open the chess page">
        {% include "partials/widgets/chess-match.njk" %}
        <span class="cell-hover-label">chess →</span>
      </a>

      {% set grdnTags = [
        'fiction','essays','music','chess','genetics','philosophy','identity',
        'language','code','diy','automotive','baking','cooking','observation',
        'prose','notes','reading','memory','place','history','tools',
        'process','craft','health','finance','sketches','interviews','book notes'
      ] %}
      <a class="tile tile-link grdn" href="/garden">
        <div class="tile-cloud" aria-hidden="true">
          {% for tag in grdnTags %}<span style="--i:{{ loop.index0 }}">{{ tag }}</span>{% endfor %}
        </div>
        <div class="tile-content">
          <div class="tile-desc">Writing, code, essays.</div>
          <div class="tile-title">garden ↗</div>
        </div>
      </a>
    </div>

    <script src="/js/dashboard.js"></script>
  </main>

  {% include "partials/big-footer.njk" %}
</body>
</html>
{%- endif -%}
