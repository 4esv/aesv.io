<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Listening — aesv.io</title>
  <meta name="description" content="Recently played, top tracks, top artists. Pulled from Spotify.">
  <link rel="icon" href="/logo-pixel.png" type="image/png">
  <meta name="theme-color" content="#F4ECD8">
  <link rel="preload" href="/fonts/birdie-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/listening.css">
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="listen">
    <header class="listen-header">
      <a class="brand" href="/">
        <img src="/logo.png" alt="" width="36" height="36">
        <span>aesv.io</span>
      </a>
      <nav class="nav-links">
        <a href="/">← dashboard</a>
        <a href="https://open.spotify.com/user/4esv" rel="noopener">Spotify ↗</a>
      </nav>
    </header>

    <section class="hero">
      <div class="eyebrow">What I'm listening to</div>
      <h1 class="display">Constant rotation.</h1>
      <p class="lede">Live from Spotify. Corridos to Norwegian death metal. No through-line — I stopped looking.</p>
    </section>

    {% if recent %}
    <section class="block now-playing">
      <div class="block-eyebrow">Last played</div>
      <div class="now-grid">
        <div class="now-art">
          {% if recent.albumArtUrl %}
            <img src="{{ recent.albumArtUrl }}" alt="Album art for {{ recent.album }}">
          {% endif %}
        </div>
        <div class="now-meta">
          <p class="now-track">{{ recent.track }}</p>
          <p class="now-artist">{{ recent.artist }}</p>
          <p class="now-album">{{ recent.album }}</p>
          {% if recent.url %}<a class="btn" href="{{ recent.url }}" rel="noopener">Open in Spotify ↗</a>{% endif %}
        </div>
      </div>
    </section>
    {% endif %}

    {% if spotify and spotify.tracks and spotify.tracks.length %}
    <section class="block">
      <div class="block-eyebrow">Top tracks · medium term</div>
      <h2 class="block-h">Five on repeat.</h2>
      <ol class="track-stack">
        {% for t in spotify.tracks %}
          <li class="track-row">
            <span class="track-num">{{ '0' + (loop.index|string) if loop.index < 10 else loop.index }}</span>
            <div class="track-meta">
              <p class="track-name">{{ t.name }}</p>
              <p class="track-artist">{{ t.artist }}</p>
            </div>
            {% if t.url %}<a class="track-link" href="{{ t.url }}" rel="noopener" aria-label="Open {{ t.name }} on Spotify">↗</a>{% endif %}
          </li>
        {% endfor %}
      </ol>
    </section>
    {% endif %}

    {% if spotify and spotify.artists and spotify.artists.length %}
    <section class="block">
      <div class="block-eyebrow">Top artists · medium term</div>
      <h2 class="block-h">Who I keep returning to.</h2>
      <ul class="artist-marquee">
        {% for a in spotify.artists %}
          <li>
            {% if a.url %}<a href="{{ a.url }}" rel="noopener">{{ a.name }}</a>{% else %}<span>{{ a.name }}</span>{% endif %}
          </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}

    {% if not spotify and not recent %}
    <section class="block empty-state">
      <div class="block-eyebrow">No data</div>
      <p>Spotify not authorized. <a href="/api/auth/spotify">Authorize</a> to populate.</p>
    </section>
    {% endif %}
  </main>

  <footer class="big-footer">
    <div class="big-footer-inner">
      <p class="footer-marquee">aesv<span class="accent">·</span>io</p>
      <p class="footer-tagline">Mexican American sentient flesh pile. Pianist, bassist, emergency drummer. I make system A talk to system B.</p>
      <div class="footer-cols">
        <div class="footer-col">
          <h4>Sites</h4>
          <ul>
            <li><a href="/">aesv.io</a></li>
            <li><a href="/work">work</a></li>
            <li><a href="/garden">garden</a></li>
            <li><a href="/music">music</a></li>
            <li><a href="/chess">chess</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Reach me</h4>
          <ul>
            <li><a href="mailto:mail@aesv.io">mail@aesv.io</a></li>
            <li><a href="https://github.com/4esv" rel="noopener">github.com/4esv</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Colophon</h4>
          <p>Spotify refreshes every 5 minutes server-side. No client tracking.</p>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© {{ now | date('Y') }} Axel Stevens · MIT</span>
        <span>Built in Ithaca, New York</span>
      </div>
    </div>
  </footer>
  <link rel="stylesheet" href="/css/dashboard.css">
</body>
</html>
