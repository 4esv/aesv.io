{%- else -%}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% include "partials/site-meta.njk" %}
  <link rel="canonical" href="https://aesv.io/activities">
  <title>activities — aesv.io</title>
  <meta name="description" content="What I'm up to. Chess.com receipts and the last Strava activity.">
  <meta property="og:type" content="website">
  <meta property="og:title" content="activities — aesv.io">
  <meta property="og:description" content="What I'm up to. Chess.com receipts and the last Strava activity.">
  <meta property="og:url" content="https://aesv.io/activities">
  <meta property="og:site_name" content="aesv.io">
  <meta property="og:image" content="https://aesv.io/logo.png">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="activities — aesv.io">
  <meta name="twitter:description" content="What I'm up to. Chess.com receipts and the last Strava activity.">
  <meta name="twitter:image" content="https://aesv.io/logo.png">
  <link rel="icon" href="/logo-pixel.png" type="image/png">
  <link rel="apple-touch-icon" href="/logo.png">
  <meta name="theme-color" content="#F4ECD8">
  <link rel="preload" href="/fonts/birdie-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/activities.css">
  <link rel="stylesheet" href="/css/transitions.css">
  {% include "partials/analytics.njk" %}
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="subpage activities">
    {% include "partials/site-header.njk" %}

    <header class="page-head">
      <h1>activities.</h1>
      <p class="lede">What I do off-screen. Chess at night, Strava in the morning. Both have an API, so both show up here.</p>
      <div class="page-cta-row">
        <a class="btn btn-sm" href="https://chess.com/member/4esv" rel="noopener">chess.com ↗</a>
        <a class="btn btn-sm" href="https://strava.com/athletes/51674641" rel="noopener">strava ↗</a>
      </div>
    </header>

    {# Chess — last-match widget only. #}
    {% if lastVictory %}
    <section class="act-section">
      <h2>Won this one.</h2>
      <div class="lv-grid">
        <div class="lv-board" id="lv-board">{{ lastVictory.svg | safe }}</div>
        <div class="lv-meta">
          <p class="lv-pair"><strong>{{ lastVictory.white }}</strong> vs <strong>{{ lastVictory.black }}</strong></p>
          <p class="lv-line">{{ lastVictory.result }}{% if lastVictory.eco %} · {{ lastVictory.eco }}{% endif %}{% if lastVictory.timeControl %} · {{ lastVictory.timeControl }}{% endif %}</p>
          {% if lastVictory.lastMove %}
          <p class="lv-line">winning move: <strong>{{ lastVictory.lastMove.from }} → {{ lastVictory.lastMove.to }}</strong></p>
          {% endif %}
          <div class="page-cta-row">
            {% if replayFramesSvg and replayFramesSvg.length %}
            <button class="btn btn-sm" type="button" id="lv-play" data-frame-count="{{ replayFramesSvg.length }}">▶ play through</button>
            <button class="btn btn-sm" type="button" id="lv-reset" hidden>↺ reset</button>
            {% endif %}
            <a class="btn btn-sm" href="{{ lastVictory.url }}" rel="noopener">chess.com ↗</a>
          </div>
          <p class="lv-replay-status" id="lv-status" aria-live="polite"></p>
        </div>
      </div>
    </section>
    {% endif %}

    {# Strava — same two-column shape as the chess widget. Map left, meta right. #}
    <section class="act-section">
      <h2>I move too.</h2>
      {% if strava %}
      <div class="lv-grid">
        <div class="lv-board strava-map">
          {% if strava.routePath %}
          {% include "partials/widgets/strava-route.njk" %}
          {% else %}
          <div class="strava-empty">no map (indoor)</div>
          {% endif %}
        </div>
        <div class="lv-meta">
          <p class="lv-pair">{{ strava.name }}</p>
          {% include "partials/widgets/strava-stats.njk" %}
          <div class="page-cta-row">
            <a class="btn btn-sm" href="https://strava.com/athletes/51674641" rel="noopener">strava profile ↗</a>
          </div>
        </div>
      </div>
      {% else %}
      <p class="empty">No recent activity. <a href="/api/auth/strava">Authorize Strava</a>.</p>
      {% endif %}
    </section>
  </main>

  {% if replayFramesSvg and replayFramesSvg.length %}
  <script id="lv-frames" type="application/json">{{ replayFramesSvg | safeJson | safe }}</script>
  <script src="/js/activities.js"></script>
  {% endif %}

  {% include "partials/big-footer.njk" %}
  <script src="/js/transitions.js"></script>
</body>
</html>
{%- endif -%}
