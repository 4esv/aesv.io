{%- if grid.isTerminal -%}
{% extends "base-text.njk" %}
{% block content %}
music
=====

{% if nowPlaying -%}
now playing: {{ nowPlaying.name | safe }} — {{ nowPlaying.artist | safe }} ({{ nowPlaying.album.name | safe }})
{% elif recent and recent.length -%}
last played: {{ recent[0].name | safe }} — {{ recent[0].artist | safe }} ({{ recent[0].album.name | safe }})
{% else -%}
no recent activity.
{% endif %}
{% if recentLog and recentLog.length %}
recent (top 5)
--------------
{% for r in recentLog -%}
{{ loop.index }}. {{ r.name | safe }} — {{ r.artist | safe }}
{% endfor %}{% endif %}
{% if instruments and instruments.length %}
what i play
-----------
{% for i in instruments -%}
- {{ i.name }} — {{ i.note }}
{% endfor %}{% endif %}
{% if albums and albums.length %}
albums
------
{% for a in albums -%}
- {{ a.name | safe }} — {{ a.artist | safe }}
{% endfor %}{% endif %}
{% if topArtists and topArtists.length %}
artists
-------
{% for a in topArtists -%}
{{ loop.index }}. {{ a.name | safe }}
{% endfor %}{% endif %}

aesv.io    /
work       /work
files      /garden
about      /about
activities /activities

mail   mail@aesv.io
github https://github.com/4esv
{% endblock %}
{%- else -%}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>music — aesv.io</title>
  <meta name="description" content="What I'm listening to and what I play. Albums, artists, tracks. Pulled live from Spotify.">
  <link rel="icon" href="/logo-pixel.png" type="image/png">
  <meta name="theme-color" content="#F4ECD8">
  <link rel="preload" href="/fonts/birdie-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/listening.css">
  <link rel="stylesheet" href="/css/music.css">
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="subpage music">
    {% include "partials/site-header.njk" %}

    <header class="page-head">
      <h1>music.</h1>
      <p class="lede">What I'm listening to, what I play, what I'd like back on cassette.</p>
      <div class="page-cta-row">
        <a class="btn btn-sm" href="https://open.spotify.com/user/4esv" rel="noopener">Open in Spotify ↗</a>
      </div>
    </header>

    {% if not hasData %}
    <section class="music-section empty-state">
      <p>Nothing yet. <a href="/api/auth/spotify">Authorize Spotify</a>.</p>
    </section>
    {% endif %}

    {% set lead = nowPlaying or (recent[0] if recent and recent.length else null) %}
    {% if lead %}
    <section class="music-section">
      <h2>Just heard.</h2>
      <div class="just-heard">
        <div class="now-grid">
          <div class="now-art">
            {% if lead.album.artUrl %}
              <img src="{{ lead.album.artUrl }}" alt="Album art for {{ lead.album.name }}" loading="eager">
            {% endif %}
          </div>
          <div class="now-meta">
            <p class="now-track">{{ lead.name }}</p>
            <p class="now-artist">{{ lead.artist }}</p>
            <p class="now-album">{{ lead.album.name }}</p>
            {% if lead.url %}<a class="btn btn-sm" href="{{ lead.url }}" rel="noopener">open in spotify ↗</a>{% endif %}
          </div>
        </div>
        {% if recentLog and recentLog.length %}
        <ol class="ledger">
          {% for r in recentLog %}
            <li class="ledger-row">
              <span class="ledger-num">{{ '0' + (loop.index|string) if loop.index < 10 else loop.index }}</span>
              <div class="ledger-meta">
                <p class="ledger-track">{{ r.name }}</p>
                <p class="ledger-artist">{{ r.artist }}{% if r.album.name %} · <span class="ledger-album">{{ r.album.name }}</span>{% endif %}</p>
              </div>
              {% if r.url %}<a class="ledger-link" href="{{ r.url }}" rel="noopener" aria-label="Open {{ r.name }} on Spotify">↗</a>{% endif %}
            </li>
          {% endfor %}
        </ol>
        {% endif %}
      </div>
    </section>
    {% endif %}

    {% if instruments and instruments.length %}
    <section class="music-section">
      <h2>I play.</h2>
      <ul class="instrument-strip">
        <li><img src="/instruments/piano.svg" alt="piano"></li>
        <li><img src="/instruments/electric-bass.svg" alt="electric bass"></li>
        <li><img src="/instruments/drumkit.svg" alt="drum kit"></li>
        <li><img src="/instruments/acoustic.svg" alt="classical guitar"></li>
        <li><img src="/instruments/ukelele.svg" alt="ukelele"></li>
        <li><img src="/instruments/amp.svg" alt="amp"></li>
      </ul>
    </section>
    {% endif %}

    {% if musicToMe %}
    <section class="music-section">
      <h2>Music to me.</h2>
      <div class="music-to-me">
        {% for line in musicToMe %}<p>{{ line }}</p>{% endfor %}
      </div>
    </section>
    {% endif %}

    {% if albums and albums.length %}
    <section class="music-section">
      <h2>Albums I've been enjoying.</h2>
      <ul class="album-grid">
        {% for a in albums %}
          <li class="album-cell">
            {% if a.url %}<a class="album-link" href="{{ a.url }}" rel="noopener">{% endif %}
              <div class="album-art">
                {% if a.artUrl %}<img src="{{ a.artUrl }}" alt="Album art for {{ a.name }} by {{ a.artist }}" loading="lazy">{% endif %}
              </div>
              <div class="album-meta">
                <p class="album-name">{{ a.name }}</p>
                <p class="album-artist">{{ a.artist }}</p>
              </div>
            {% if a.url %}</a>{% endif %}
          </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}

    {% if topArtists and topArtists.length %}
    <section class="music-section">
      <h2>Artists in my rotation.</h2>
      <ul class="artist-cloud">
        {% for a in topArtists %}
          <li>
            {% if a.url %}<a href="{{ a.url }}" rel="noopener">{{ a.name }}</a>{% else %}<span>{{ a.name }}</span>{% endif %}
          </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}
  </main>

  {% include "partials/big-footer.njk" %}
</body>
</html>
{%- endif -%}
