{%- if grid.isTerminal -%}
{% extends "base-text.njk" %}
{% block content %}
music
=====

{% if nowPlaying -%}
now playing: {{ nowPlaying.name | safe }} — {{ nowPlaying.artist | safe }} ({{ nowPlaying.album.name | safe }})
{% elif recent and recent.length -%}
last played: {{ recent[0].name | safe }} — {{ recent[0].artist | safe }} ({{ recent[0].album.name | safe }})
{% else -%}
no recent activity.
{% endif %}
{% if recentLog and recentLog.length %}
recent (top 5)
--------------
{% for r in recentLog -%}
{{ loop.index }}. {{ r.name | safe }} — {{ r.artist | safe }}
{% endfor %}{% endif %}
{% if instruments and instruments.length %}
what i play
-----------
{% for i in instruments -%}
- {{ i.name }} — {{ i.note }}
{% endfor %}{% endif %}
{% if albums and albums.length %}
albums
------
{% for a in albums -%}
- {{ a.name | safe }} — {{ a.artist | safe }}
{% endfor %}{% endif %}
{% if topArtists and topArtists.length %}
artists
-------
{% for a in topArtists -%}
{{ loop.index }}. {{ a.name | safe }}
{% endfor %}{% endif %}

aesv.io    /
work       /work
feed       /feed
about      /about
activities /activities

mail   axel@aesv.io
github https://github.com/4esv
{% endblock %}
{%- else -%}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% include "partials/site-meta.njk" %}
  <link rel="dns-prefetch" href="https://i.scdn.co">
  <link rel="dns-prefetch" href="https://mosaic.scdn.co">
  <link rel="dns-prefetch" href="https://image-cdn-ak.spotifycdn.com">
  <link rel="dns-prefetch" href="https://image-cdn-fa.spotifycdn.com">
  <link rel="canonical" href="https://aesv.io/music">
  <title>music — aesv.io</title>
  <meta name="description" content="What I'm listening to and what I play. Albums, artists, tracks. Pulled live from Spotify.">
  <meta property="og:type" content="website">
  <meta property="og:title" content="music — aesv.io">
  <meta property="og:description" content="What I'm listening to and what I play. Albums, artists, tracks. Pulled live from Spotify.">
  <meta property="og:url" content="https://aesv.io/music">
  <meta property="og:site_name" content="aesv.io">
  <meta property="og:image" content="https://aesv.io/logo.png">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="music — aesv.io">
  <meta name="twitter:description" content="What I'm listening to and what I play. Albums, artists, tracks. Pulled live from Spotify.">
  <meta name="twitter:image" content="https://aesv.io/logo.png">
  <link rel="icon" href="/logo-pixel.png" type="image/png">
  <link rel="apple-touch-icon" href="/logo.png">
  <meta name="theme-color" content="#F4ECD8">
  <link rel="preload" href="/fonts/birdie-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/listening.css">
  <link rel="stylesheet" href="/css/music.css">
  <link rel="stylesheet" href="/css/transitions.css">
  {% include "partials/analytics.njk" %}
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="subpage music">
    {% include "partials/site-header.njk" %}

    <header class="page-head">
      <h1>music.</h1>
      <p class="lede">What I'm listening to, playing, and practicing. Closest thing I have to a daily practice. I play to think; sit with a chord that's bothering me until it stops.</p>
      <div class="page-cta-row">
        <a class="btn btn-sm" href="https://open.spotify.com/user/4esv" rel="noopener">Open in Spotify ↗</a>
      </div>
    </header>

    {% if not hasData %}
    <section class="music-section empty-state">
      <p>Nothing yet. <a href="/api/auth/spotify">Authorize Spotify</a>.</p>
    </section>
    {% endif %}

    {% set lead = nowPlaying or (recent[0] if recent and recent.length else null) %}
    {% if lead %}
    <section class="music-section">
      <h2>Just heard.</h2>
      <div class="just-heard">
        <div class="now-grid">
          <div class="now-art">
            {% if lead.album.artUrl %}
              <img src="{{ lead.album.artUrl }}" alt="Album art for {{ lead.album.name }}" loading="eager">
            {% endif %}
          </div>
          <div class="now-meta">
            <p class="now-track">{{ lead.name }}</p>
            <p class="now-artist">{{ lead.artist }}</p>
            <p class="now-album">{{ lead.album.name }}</p>
            {% if lead.url %}<a class="btn btn-sm" href="{{ lead.url }}" rel="noopener">open in spotify ↗</a>{% endif %}
          </div>
        </div>
        {% if recentLog and recentLog.length %}
        <ol class="ledger" start="2">
          {% for r in recentLog %}
            {% set n = loop.index + 1 %}
            <li class="ledger-row">
              <span class="ledger-num">{{ '0' + (n|string) if n < 10 else n }}</span>
              <div class="ledger-meta">
                <p class="ledger-track">{{ r.name }}</p>
                <p class="ledger-artist">{{ r.artist }}{% if r.album.name %} · <span class="ledger-album">{{ r.album.name }}</span>{% endif %}</p>
              </div>
              {% if r.url %}<a class="ledger-link" href="{{ r.url }}" rel="noopener" aria-label="Open {{ r.name }} on Spotify">↗</a>{% endif %}
            </li>
          {% endfor %}
        </ol>
        {% endif %}
      </div>
    </section>
    {% endif %}

    {% if albums and albums.length %}
    <section class="music-section">
      <h2>Top albums.</h2>
      <ul class="album-grid">
        {% for a in albums %}
          <li class="album-cell">
            {% if a.url %}<a class="album-link" href="{{ a.url }}" rel="noopener">{% endif %}
              <div class="album-art">
                {% if a.artUrl %}<img src="{{ a.artUrl }}" alt="Album art for {{ a.name }} by {{ a.artist }}" loading="lazy">{% endif %}
              </div>
              <div class="album-meta">
                <p class="album-name">{{ a.name }}</p>
                <p class="album-artist">{{ a.artist }}</p>
              </div>
            {% if a.url %}</a>{% endif %}
          </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}

    <section class="music-section">
      <h2>I play.</h2>
      <ul class="instrument-room" aria-label="Instruments I play">
        <li class="instrument" data-instrument="drums" tabindex="0">
          <img src="/instruments/drumkit.svg" alt="">
          <span class="instrument-label">
            <strong>Drums</strong>
            Will play if I must. I have fun, the people trying to play to my beat don't.
          </span>
        </li>
        <li class="instrument" data-instrument="piano" tabindex="0">
          <img src="/instruments/piano.svg" alt="">
          <span class="instrument-label">
            <strong>Piano / Keys</strong>
            Ok enough for open mic, go to for noodling and accompanying.
          </span>
        </li>
        <li class="instrument" data-instrument="bass" tabindex="0">
          <img src="/instruments/electric-bass.svg" alt="">
          <span class="instrument-label">
            <strong>Bass</strong>
            Most rehearsed, least talented. I will hold it down but don't expect fills.
          </span>
        </li>
        <li class="instrument" data-instrument="guitar" tabindex="0">
          <img src="/instruments/guitar.png" alt="">
          <span class="instrument-label">
            <strong>Guitar</strong>
            If I must, ok enough to follow tabs and play rythm. Love my SG tho.
          </span>
        </li>
        <li class="instrument" data-instrument="amp" aria-hidden="true">
          <img src="/instruments/amp.svg" alt="">
        </li>
        <li class="instrument" data-instrument="ukulele" tabindex="0">
          <img src="/instruments/ukelele.svg" alt="">
          <span class="instrument-label">
            <strong>Ukulele</strong>
            My favorite for traveling, I have a baritone one so it's like a 2/3 guitar.
          </span>
        </li>
      </ul>
    </section>

    {% if learning and learning.length %}
    <section class="music-section">
      <h2>Learning these.</h2>
      <ul class="album-grid learning-grid">
        {% for t in learning %}
          <li class="album-cell">
            {% if t.url %}<a class="album-link" href="{{ t.url }}" rel="noopener">{% endif %}
              <div class="album-art">
                {% if t.album.artUrl %}<img src="{{ t.album.artUrl }}" alt="Album art for {{ t.name }} by {{ t.artist }}" loading="lazy">{% endif %}
              </div>
              <div class="album-meta">
                <p class="album-name">{{ t.name }}</p>
                <p class="album-artist">{{ t.note }}</p>
              </div>
            {% if t.url %}</a>{% endif %}
          </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}

  </main>

  {% include "partials/big-footer.njk" %}
  <script src="/js/transitions.js"></script>
</body>
</html>
{%- endif -%}
