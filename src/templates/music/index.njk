{%- if grid.isTerminal -%}
{% extends "base-text.njk" %}
{% block content %}
music
=====

{% if nowPlaying -%}
now playing: {{ nowPlaying.name | safe }} — {{ nowPlaying.artist | safe }} ({{ nowPlaying.album.name | safe }})
{% elif recent and recent.length -%}
last played: {{ recent[0].name | safe }} — {{ recent[0].artist | safe }} ({{ recent[0].album.name | safe }})
{% else -%}
no recent activity.
{% endif %}
{% if albums and albums.length %}
albums
------
{% for a in albums -%}
- {{ a.name | safe }} — {{ a.artist | safe }}
{% endfor %}{% endif %}
{% if topArtists and topArtists.length %}
artists
-------
{% for a in topArtists -%}
{{ loop.index }}. {{ a.name | safe }}{% if a.followers %} ({{ a.followers }} followers){% endif %}
{% endfor %}{% endif %}
{% if recent and recent.length %}
recent
------
{% for r in recent -%}
- {{ r.name | safe }} — {{ r.artist | safe }}
{% endfor %}{% endif %}

aesv.io   /
work      /work
garden    /garden
chess     /chess
listening /listening

mail   mail@aesv.io
github https://github.com/4esv
{% endblock %}
{%- else -%}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>music — aesv.io</title>
  <meta name="description" content="What I'm listening to. Albums, artists, tracks. Pulled live from Spotify.">
  <link rel="icon" href="/logo-pixel.png" type="image/png">
  <meta name="theme-color" content="#F4ECD8">
  <link rel="preload" href="/fonts/birdie-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/listening.css">
  <link rel="stylesheet" href="/css/music.css">
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="music">
    <header class="listen-header">
      <a class="brand" href="/">
        <img src="/logo.png" alt="" width="36" height="36">
        <span>aesv.io</span>
      </a>
      <nav class="nav-links">
        <a href="/">← dashboard</a>
        <a href="/listening">listening</a>
        <a href="https://open.spotify.com/user/4esv" rel="noopener">Spotify ↗</a>
      </nav>
    </header>

    <section class="hero music-hero">
      <div class="eyebrow">music</div>
      <h1 class="display">albums for everything.</h1>
    </section>

    {% if not hasData %}
    <section class="block empty-state">
      <div class="block-eyebrow">no signal</div>
      <p>Nothing yet. <a href="/api/auth/spotify">Authorize Spotify</a>.</p>
    </section>
    {% endif %}

    {% set lead = nowPlaying or (recent[0] if recent and recent.length else null) %}
    {% if lead %}
    <section class="block now-playing">
      <div class="block-eyebrow">{% if nowPlaying %}now playing{% else %}last played{% endif %}</div>
      <div class="now-grid">
        <div class="now-art">
          {% if lead.album.artUrl %}
            <img src="{{ lead.album.artUrl }}" alt="Album art for {{ lead.album.name }}" loading="eager">
          {% endif %}
        </div>
        <div class="now-meta">
          <p class="now-track">{{ lead.name }}</p>
          <p class="now-artist">{{ lead.artist }}</p>
          <p class="now-album">{{ lead.album.name }}</p>
          {% if lead.url %}<a class="btn" href="{{ lead.url }}" rel="noopener">Open in Spotify ↗</a>{% endif %}
        </div>
      </div>
    </section>
    {% endif %}

    {% if albums and albums.length %}
    <section class="block">
      <div class="block-eyebrow">albums · {{ albums.length }}</div>
      <ul class="album-grid">
        {% for a in albums %}
          <li class="album-cell">
            {% if a.url %}<a class="album-link" href="{{ a.url }}" rel="noopener">{% endif %}
              <div class="album-art">
                {% if a.artUrl %}<img src="{{ a.artUrl }}" alt="Album art for {{ a.name }} by {{ a.artist }}" loading="lazy">{% endif %}
              </div>
              <div class="album-meta">
                <p class="album-name">{{ a.name }}</p>
                <p class="album-artist">{{ a.artist }}</p>
              </div>
            {% if a.url %}</a>{% endif %}
          </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}

    {% if topArtists and topArtists.length %}
    <section class="block">
      <div class="block-eyebrow">artists · {{ topArtists.length }}</div>
      <ol class="artist-stack">
        {% for a in topArtists %}
          <li class="artist-row">
            <span class="artist-num">{{ '0' + (loop.index|string) if loop.index < 10 else loop.index }}</span>
            <div class="artist-art">
              {% if a.imageUrl %}<img src="{{ a.imageUrl }}" alt="" loading="lazy">{% endif %}
            </div>
            <div class="artist-meta">
              <p class="artist-name">
                {% if a.url %}<a href="{{ a.url }}" rel="noopener">{{ a.name }}</a>{% else %}{{ a.name }}{% endif %}
              </p>
              {% if a.followers %}
                <p class="artist-stat">{{ a.followers }} followers</p>
              {% elif a.genres and a.genres.length %}
                <p class="artist-stat">{{ a.genres | join(' · ') }}</p>
              {% endif %}
            </div>
          </li>
        {% endfor %}
      </ol>
    </section>
    {% endif %}

    {% if recent and recent.length %}
    <section class="block">
      <div class="block-eyebrow">recent · {{ recent.length }}</div>
      <ol class="ledger">
        {% for r in recent %}
          <li class="ledger-row">
            <span class="ledger-num">{{ '0' + (loop.index|string) if loop.index < 10 else loop.index }}</span>
            <div class="ledger-meta">
              <p class="ledger-track">{{ r.name }}</p>
              <p class="ledger-artist">{{ r.artist }}{% if r.album.name %} · <span class="ledger-album">{{ r.album.name }}</span>{% endif %}</p>
            </div>
            {% if r.url %}<a class="ledger-link" href="{{ r.url }}" rel="noopener" aria-label="Open {{ r.name }} on Spotify">↗</a>{% endif %}
          </li>
        {% endfor %}
      </ol>
    </section>
    {% endif %}
  </main>

  <footer class="big-footer">
    <div class="big-footer-inner">
      <p class="footer-marquee">aesv<span class="accent">·</span>io</p>
      <p class="footer-tagline">Mexican American sentient flesh pile. Pianist, bassist, emergency drummer. I make system A talk to system B.</p>
      <div class="footer-cols">
        <div class="footer-col">
          <h4>Sites</h4>
          <ul>
            <li><a href="/">aesv.io</a></li>
            <li><a href="/work">work</a></li>
            <li><a href="/garden">garden</a></li>
            <li><a href="/music" aria-current="page">music</a></li>
            <li><a href="/chess">chess</a></li>
            <li><a href="/listening">listening</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Reach me</h4>
          <ul>
            <li><a href="mailto:mail@aesv.io">mail@aesv.io</a></li>
            <li><a href="https://github.com/4esv" rel="noopener">github.com/4esv</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Colophon</h4>
          <p>Spotify data cached 5 minutes server-side. No client tracking.</p>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© {{ now | date('Y') }} Axel Stevens · MIT</span>
        <span>Built in Ithaca, New York</span>
      </div>
    </div>
  </footer>
</body>
</html>
{%- endif -%}
