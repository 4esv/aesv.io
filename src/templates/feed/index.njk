<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% include "partials/site-meta.njk" %}
  <link rel="canonical" href="https://aesv.io/feed">
  <title>feed — aesv.io</title>
  <meta name="description" content="A scattered notebook. Fiction, essays, fragments — discoverable by tag and date.">
  <meta property="og:type" content="website">
  <meta property="og:title" content="feed — aesv.io">
  <meta property="og:description" content="A scattered notebook. Fiction, essays, fragments — discoverable by tag and date.">
  <meta property="og:url" content="https://aesv.io/feed">
  <meta property="og:site_name" content="aesv.io">
  <meta property="og:image" content="https://aesv.io/logo.png">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="feed — aesv.io">
  <meta name="twitter:description" content="A scattered notebook. Fiction, essays, fragments — discoverable by tag and date.">
  <meta name="twitter:image" content="https://aesv.io/logo.png">
  <link rel="icon" href="/logo-pixel.png" type="image/png">
  <link rel="apple-touch-icon" href="/logo.png">
  <meta name="theme-color" content="#F4ECD8">
  <link rel="preload" href="/fonts/birdie-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/feed.css">
  <link rel="stylesheet" href="/css/transitions.css">
  {% include "partials/analytics.njk" %}
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="subpage feed-shell feed-discovery">
    {% include "partials/site-header.njk" %}

    <header class="page-head">
      <h1>feed.</h1>
    </header>

    <section class="feed-controls" aria-label="Filter the feed">
      <label class="feed-search">
        <input id="feed-search" type="search" class="field" placeholder="tag, title…" autocomplete="off" aria-label="Search">
      </label>

      <div class="feed-view" role="group" aria-label="Layout">
        <span class="view-label">view</span>
        <button class="view-chip is-active" data-view="grid" type="button" aria-pressed="true">grid</button>
        <button class="view-chip" data-view="list" type="button" aria-pressed="false">list</button>
      </div>
    </section>

    <section class="feed-grid" data-view="grid" aria-label="Notes">
      <div class="list-head" aria-hidden="true">
        <span>title</span>
        <span>tags</span>
        <span></span>
      </div>
      {% if entries.length === 0 %}
        <p class="empty">Nothing here yet.</p>
      {% endif %}
      {% for entry in entries %}
        <a class="note-card"
           href="{{ basePath }}/{{ entry.slug }}"
           data-title="{{ entry.title | lower }}"
           data-summary="{{ entry.summary | lower }}"
           data-tags="{{ (entry.tags or []) | join(' ') | lower }}">
          <h2 class="note-title">{{ entry.title }}</h2>
          {% if entry.summary %}<p class="note-summary">{{ entry.summary }}</p>{% endif %}
          <div class="note-meta">
            {% for tag in entry.tags %}<span class="pill">{{ tag }}</span>{% endfor %}
          </div>
          <span class="note-arrow" aria-hidden="true">↗</span>
        </a>
      {% endfor %}
      <p id="feed-empty" class="empty" style="display:none">No matches.</p>
    </section>
  </main>

  {% include "partials/big-footer.njk" %}

  <script src="/js/feed.js"></script>
  <script src="/js/transitions.js"></script>
</body>
</html>
