<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% include "partials/site-meta.njk" %}
  {% set canonicalUrl = 'https://aesv.io' + (canonicalBase or '/feed') + '/' + entry.slug %}
  {% set sectionLabel = 'work' if entry.type === 'case-study' else 'feed' %}
  <link rel="canonical" href="{{ canonicalUrl }}">
  <title>{{ entry.title }} · {{ sectionLabel }} · aesv.io</title>
  <meta name="description" content="{{ entry.summary or 'Entry in Axel Stevens\' notebook.' }}">
  <meta property="og:type" content="article">
  <meta property="og:title" content="{{ entry.title }} · {{ sectionLabel }} · aesv.io">
  <meta property="og:description" content="{{ entry.summary or 'Entry in Axel Stevens\' notebook.' }}">
  <meta property="og:url" content="{{ canonicalUrl }}">
  <meta property="og:site_name" content="aesv.io">
  <meta property="og:image" content="https://aesv.io/logo.png">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ entry.title }} · {{ sectionLabel }} · aesv.io">
  <meta name="twitter:description" content="{{ entry.summary or 'Entry in Axel Stevens\' notebook.' }}">
  <meta name="twitter:image" content="https://aesv.io/logo.png">
  <link rel="icon" href="/logo-pixel.png" type="image/png">
  <link rel="apple-touch-icon" href="/logo.png">
  <meta name="theme-color" content="#F4ECD8">
  <link rel="preload" href="/fonts/birdie-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/katex.min.css">
  <link rel="stylesheet" href="/css/highlight.css">
  <link rel="stylesheet" href="/css/feed.css">
  {% if entry.type === 'case-study' %}<link rel="stylesheet" href="/css/work.css">
  <link rel="stylesheet" href="/css/case-study.css">{% endif %}
  {% for href in entry.extraCss %}<link rel="stylesheet" href="{{ href }}">{% endfor %}
  <link rel="stylesheet" href="/css/transitions.css">
  {% include "partials/analytics.njk" %}
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="subpage feed-shell entry{% if entry.type === 'case-study' %} case-study-detail{% endif %}">
    {% include "partials/site-header.njk" %}

    <header class="page-head">
      <div class="entry-meta">
        {% if entry.date %}<time>{{ entry.date }}</time>{% endif %}
        {% for tag in entry.tags %}<span class="tag">{{ tag }}</span>{% endfor %}
      </div>
      <h1>{{ entry.title }}</h1>
      {% if entry.summary %}<p class="lede">{{ entry.summary }}</p>{% endif %}
      <div class="page-cta-row">
        {% if entry.type === 'case-study' %}
        <a class="btn btn-sm btn-back-to-work" href="/work">← back to work</a>
        {% else %}
        <a class="btn btn-sm" href="{{ basePath }}">← all entries</a>
        {% endif %}
        {% if entry.repo %}
        <a class="btn btn-sm" href="{{ entry.repo }}" rel="noopener">code on github</a>
        {% endif %}
      </div>
    </header>

    {% if entry.type === 'case-study' and (entry.impact or entry.stack) %}
    <section class="case-fact-row">
      {% if entry.impact %}
      <div class="case-fact case-fact-impact">
        <p>{{ entry.impact }}</p>
      </div>
      {% endif %}
      {% if entry.stack %}
      <div class="case-fact case-fact-stack">
        <p>{{ entry.stack }}</p>
      </div>
      {% endif %}
    </section>
    {% endif %}

    <article class="prose{% if entry.type === 'case-study' %} case-prose{% endif %}">
      {{ html | safe }}
    </article>
  </main>

  {% include "partials/big-footer.njk" %}
  <script src="/js/transitions.js"></script>
  {% for src in entry.extraJs %}<script src="{{ src }}" defer></script>{% endfor %}
</body>
</html>
