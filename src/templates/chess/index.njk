{%- if grid.isTerminal -%}
{% extends "base-text.njk" %}
{% block content %}
chess.
======
{{ username }} on chess.com{% if profile and profile.country %} · {{ profile.country }}{% endif %}

{% if stats %}ratings
-------
format    current   best    worst   W       L       D
{% for r in stats.ratings %}{{ r.format | padEnd(10) }}{{ (r.current or '—') | string | padEnd(10) }}{{ (r.best or '—') | string | padEnd(8) }}{{ (r.worst or '—') | string | padEnd(8) }}{{ r.win | string | padEnd(8) }}{{ r.loss | string | padEnd(8) }}{{ r.draw | string }}
{% endfor %}{% if stats.tactics %}tactics: best {{ stats.tactics.highest or '—' }} · low {{ stats.tactics.lowest or '—' }}
{% endif %}{% if stats.puzzleRush %}puzzle rush: {{ stats.puzzleRush.score }} ({{ stats.puzzleRush.totalAttempts }} attempts)
{% endif %}career: {{ stats.totals.win }}W · {{ stats.totals.loss }}L · {{ stats.totals.draw }}D
{% else %}ratings unavailable.{% endif %}

last {{ games.length or 0 }} games
{{ '-' | repeat(20) }}
{% if games and games.length %}#   date        out  color  vs                       fmt      time
{% for g in games %}{{ loop.index | string | padStart(2, '0') }}  {{ g.date | padEnd(10) }}  {{ g.outcomeChar }}    {{ g.color | padEnd(5) }}  {{ g.opponent | truncate(22) | padEnd(24) }} {{ g.formatLabel | padEnd(8) }} {{ g.timeControl }}
{% endfor %}
record over recent: {{ record.win }}W · {{ record.loss }}L · {{ record.draw }}D
{% else %}no games loaded.
{% endif %}
{% if lastVictory %}
last victory
------------
{{ lastVictory.white }} vs {{ lastVictory.black }} — {{ lastVictory.result }}
{{ lastVictory.url }}
{% if lastVictory.board %}{% for line in lastVictory.board %}{{ line }}
{% endfor %}{% endif %}{% endif %}
---
