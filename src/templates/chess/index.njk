work        /work
garden      /garden
music       /music
chess       /chess (current)
listening   /listening

email       mail@aesv.io
github      https://github.com/4esv

MIT License. {{ now | date('Y') }}.
{% endblock %}
{%- else -%}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>chess — aesv.io</title>
  <meta name="description" content="Chess.com receipts for 4esv. Ratings, recent games, last victory.">
  <link rel="icon" href="/logo-pixel.png" type="image/png">
  <link rel="apple-touch-icon" href="/logo.png">
  <meta name="theme-color" content="#F4ECD8">
  <link rel="preload" href="/fonts/birdie-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/chess.css">
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="chess">
    {% set route = '/chess' %}
    {% set pageEyebrow = 'chess.com / ' + username %}
    {% include "partials/site-header.njk" %}

    <section class="chess-hero">
      <div class="eyebrow">chess.com · {{ username }}</div>
      <h1 class="display">I play. Receipts below.</h1>
      <div class="hero-record">
        {% if record.win or record.loss or record.draw %}
        <span class="rec-w">{{ record.win }}W</span>
        <span class="rec-sep">·</span>
        <span class="rec-l">{{ record.loss }}L</span>
        <span class="rec-sep">·</span>
        <span class="rec-d">{{ record.draw }}D</span>
        <span class="rec-meta">last {{ games.length }} games</span>
        {% else %}
        <span class="rec-meta">no recent games.</span>
        {% endif %}
      </div>
    </section>

    {% if featured.lastWin or featured.lastLoss %}
    <section class="chess-block">
      <div class="block-eyebrow">Both sides · most recent</div>
      <div class="board-pair">
        {% if featured.lastWin %}
        <a class="board-card outcome-win" href="{{ featured.lastWin.url }}" rel="noopener">
          <div class="bc-art">{% if featured.lastWin.svg %}{{ featured.lastWin.svg | safe }}{% endif %}</div>
          <div class="bc-meta">
            <span class="bc-badge badge-win">W</span>
            <span class="bc-opp">vs {{ featured.lastWin.opponent }}</span>
            <span class="bc-line">{{ featured.lastWin.color }} · {{ featured.lastWin.formatLabel }} · {{ featured.lastWin.timeControl }}</span>
            {% if featured.lastWin.eco %}<span class="bc-eco">{{ featured.lastWin.eco }}</span>{% endif %}
          </div>
        </a>
        {% endif %}
        {% if featured.lastLoss %}
        <a class="board-card outcome-loss" href="{{ featured.lastLoss.url }}" rel="noopener">
          <div class="bc-art">{% if featured.lastLoss.svg %}{{ featured.lastLoss.svg | safe }}{% endif %}</div>
          <div class="bc-meta">
            <span class="bc-badge badge-loss">L</span>
            <span class="bc-opp">vs {{ featured.lastLoss.opponent }}</span>
            <span class="bc-line">{{ featured.lastLoss.color }} · {{ featured.lastLoss.formatLabel }} · {{ featured.lastLoss.timeControl }}</span>
            {% if featured.lastLoss.eco %}<span class="bc-eco">{{ featured.lastLoss.eco }}</span>{% endif %}
          </div>
        </a>
        {% endif %}
      </div>
    </section>
    {% endif %}

    <section class="chess-block">
      <div class="block-eyebrow">Ratings</div>
      {% if stats and stats.ratings.length %}
      <ul class="rating-strip">
        {% for r in stats.ratings %}
        <li class="rating-card">
          <div class="rc-format">{{ r.format }}</div>
          <div class="rc-current">{{ r.current or '—' }}</div>
          <div class="rc-row">
            <span><em>best</em> {{ r.best or '—' }}</span>
            <span><em>worst</em> {{ r.worst or '—' }}</span>
          </div>
          <div class="rc-record">
            <span class="rec-w">{{ r.win }}W</span>
            <span class="rec-l">{{ r.loss }}L</span>
            <span class="rec-d">{{ r.draw }}D</span>
          </div>
        </li>
        {% endfor %}
      </ul>
      {% if stats.tactics or stats.puzzleRush %}
      <ul class="puzzle-strip">
        {% if stats.tactics %}
        <li class="puzzle-card">
          <div class="pc-label">tactics</div>
          <div class="pc-value">{{ stats.tactics.highest or '—' }}</div>
          <div class="pc-meta">low {{ stats.tactics.lowest or '—' }}</div>
        </li>
        {% endif %}
        {% if stats.puzzleRush %}
        <li class="puzzle-card">
          <div class="pc-label">puzzle rush</div>
          <div class="pc-value">{{ stats.puzzleRush.score }}</div>
          <div class="pc-meta">{{ stats.puzzleRush.totalAttempts }} attempts</div>
        </li>
        {% endif %}
      </ul>
      {% endif %}
      {% else %}
      <p class="empty">ratings unavailable.</p>
      {% endif %}
    </section>

    <section class="chess-block">
      <div class="block-eyebrow">Recent · last {{ games.length or 0 }}</div>
      {% if games.length %}
      <ol class="ledger">
        <li class="ledger-head">
          <span class="lc-num">#</span>
          <span class="lc-date">date</span>
          <span class="lc-out">out</span>
          <span class="lc-color">color</span>
          <span class="lc-opp">opponent</span>
          <span class="lc-fmt">format</span>
          <span class="lc-tc">time</span>
          <span class="lc-link"></span>
        </li>
        {% for g in games %}
        <li class="ledger-row outcome-{{ g.outcome }}">
          <span class="lc-num">{% if loop.index < 10 %}0{{ loop.index }}{% else %}{{ loop.index }}{% endif %}</span>
          <span class="lc-date">{{ g.date }}</span>
          <span class="lc-out badge-{{ g.outcome }}">{{ g.outcomeChar }}</span>
          <span class="lc-color">{{ g.color }}</span>
          <span class="lc-opp">vs <strong>{{ g.opponent }}</strong>{% if g.opponentRating %} <em>{{ g.opponentRating }}</em>{% endif %}</span>
          <span class="lc-fmt">{{ g.formatLabel }}</span>
          <span class="lc-tc">{{ g.timeControl }}</span>
          <a class="lc-link" href="{{ g.url }}" rel="noopener" aria-label="View on chess.com">↗</a>
        </li>
        {% endfor %}
      </ol>
      {% else %}
      <p class="empty">no games loaded.</p>
      {% endif %}
    </section>

    {% if lastVictory %}
    <section class="chess-block">
      <div class="block-eyebrow">Last victory</div>
      <div class="lv-grid">
        <div class="lv-board">{{ lastVictory.svg | safe }}</div>
        <div class="lv-meta">
          <p class="lv-pair"><strong>{{ lastVictory.white }}</strong> vs <strong>{{ lastVictory.black }}</strong></p>
          <p class="lv-line">{{ lastVictory.result }}{% if lastVictory.eco %} · {{ lastVictory.eco }}{% endif %}{% if lastVictory.timeControl %} · {{ lastVictory.timeControl }}{% endif %}</p>
          <a class="btn" href="{{ lastVictory.url }}" rel="noopener">Open on chess.com</a>
        </div>
      </div>
    </section>
    {% endif %}

  </main>

  {% include "partials/big-footer.njk" %}
</body>
</html>
{%- endif -%}
