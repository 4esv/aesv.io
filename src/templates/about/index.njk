<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>about — aesv.io</title>
  <meta name="description" content="{{ about.summary }}">
  <link rel="icon" href="/logo-pixel.png" type="image/png">
  <link rel="apple-touch-icon" href="/logo.png">
  <meta name="theme-color" content="#F4ECD8">
  <link rel="preload" href="/fonts/birdie-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/grdn.css">
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="subpage about">
    {% set route = '/about' %}
    {% include "partials/site-header.njk" %}

    <header class="page-head">
      <h1>{{ about.title | lower }}.</h1>
      <p class="lede">{{ about.summary }}</p>
      <div class="page-cta-row">
        <a class="btn btn-sm" href="mailto:mail@aesv.io">mail@aesv.io ↗</a>
        <a class="btn btn-sm" href="https://github.com/4esv" rel="noopener">github ↗</a>
      </div>
    </header>

    <article class="prose">
      {{ about.html | safe }}
    </article>
  </main>

  {% include "partials/big-footer.njk" %}
</body>
</html>
