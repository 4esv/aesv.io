<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ study.title }} — work · aesv.io</title>
  <meta name="description" content="{{ study.summary }}">
  <link rel="icon" href="/logo-pixel.png" type="image/png">
  <link rel="apple-touch-icon" href="/logo.png">
  <meta name="theme-color" content="#F4ECD8">
  <link rel="preload" href="/fonts/birdie-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/highlight.css">
  <link rel="stylesheet" href="/css/grdn.css">
  <link rel="stylesheet" href="/css/work.css">
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="subpage case-study-detail">
    {% include "partials/site-header.njk" %}

    <header class="page-head">
      <div class="case-card-meta">
        <span>{{ study.year }}</span>
        <span>{{ study.tag }}</span>
      </div>
      <h1>{{ study.title }}</h1>
      {% if study.summary %}<p class="lede">{{ study.summary }}</p>{% endif %}
      <div class="page-cta-row">
        <a class="btn btn-sm" href="/work">← all case studies</a>
        <a class="btn btn-sm" href="mailto:mail@aesv.io?subject={{ study.title | urlencode }}">work like this ↗</a>
      </div>
    </header>

    {% if study.impact or study.stack %}
    <section class="case-fact-row">
      {% if study.impact %}
      <div class="case-fact case-fact-impact">
        <p>{{ study.impact }}</p>
      </div>
      {% endif %}
      {% if study.stack %}
      <div class="case-fact case-fact-stack">
        <p>{{ study.stack }}</p>
      </div>
      {% endif %}
    </section>
    {% endif %}

    <article class="prose case-prose">
      {{ html | safe }}
    </article>
  </main>

  {% include "partials/big-footer.njk" %}
</body>
</html>
