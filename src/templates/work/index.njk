<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>work — aesv.io</title>
  <meta name="description" content="Axel Stevens — systems integrator. Six case studies. Available for contract work.">
  <link rel="icon" href="/logo-pixel.png" type="image/png">
  <link rel="apple-touch-icon" href="/logo.png">
  <meta name="theme-color" content="#F4ECD8">
  <link rel="preload" href="/fonts/birdie-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/work.css">
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="subpage work-shell">
    {% include "partials/site-header.njk" %}

    <header class="page-head">
      <h1>work.</h1>
      <p class="lede">Systems integrator at Cornell's College of Human Ecology. I make system A talk to system B — workflow platforms, MDMs, directory services, AI pipelines, the legacy stack that has to keep running.</p>
      <div class="page-cta-row">
        <a class="btn btn-sm btn-primary" href="mailto:mail@aesv.io">hire me ↗</a>
        <a class="btn btn-sm" href="https://github.com/4esv" rel="noopener">github ↗</a>
      </div>
    </header>

    <section class="work-section" id="case-studies">
      <h2>Things I've done.</h2>
      <ul class="case-card-grid">
        {% for cs in caseStudies %}
        <li>
          <a class="case-card" href="/work/{{ cs.slug }}">
            <div class="case-card-meta">
              <span>{{ cs.year }}</span>
              <span>{{ cs.tag }}</span>
            </div>
            <h3 class="case-card-title">{{ cs.title }}</h3>
            <p class="case-card-summary">{{ cs.summary }}</p>
            {% if cs.impact %}<p class="case-card-impact">{{ cs.impact }}</p>{% endif %}
            <span class="case-card-arrow" aria-hidden="true">read ↗</span>
          </a>
        </li>
        {% endfor %}
      </ul>
    </section>

    <section class="work-section" id="services">
      <h2>Things I do.</h2>
      <div class="services">
        {% for s in services %}
        <div class="service">
          <span class="num">{{ '0' + (loop.index|string) if loop.index < 10 else loop.index|string }}</span>
          <h3>{{ s.title }}</h3>
          <p>{{ s.body }}</p>
        </div>
        {% endfor %}
      </div>
    </section>

    <section class="work-section">
      <h2>Who I do it for.</h2>
      <div class="client-profile">
        <p>Small businesses, nonprofits, and higher-ed-adjacent shops that need engineering, not a vendor demo.</p>
        <p>Vague reaches cost money. I scope tightly, quote concretely. Two systems that don't talk? Tell me.</p>
      </div>
    </section>

    <section class="work-section contact-block" id="contact">
      <h2>Let's talk.</h2>
      <p>Email me what you're trying to connect. Scope and quote back within two business days.</p>
      <div class="page-cta-row" style="justify-content: center;">
        <a class="btn btn-primary" href="mailto:mail@aesv.io">mail@aesv.io →</a>
      </div>
    </section>
  </main>

  {% include "partials/big-footer.njk" %}
</body>
</html>
