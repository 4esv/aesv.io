{# Mobile minimap — only rendered on small screens via CSS display:none on desktop #}
<div id="minimap" aria-hidden="true" data-side="right">
  <div id="minimap-track">
    {# Tile markers injected by mobile-scroll.js at runtime #}
  </div>
  <button id="minimap-hand-toggle" title="Switch side" aria-label="Switch handedness">&#x21C4;</button>
</div>
