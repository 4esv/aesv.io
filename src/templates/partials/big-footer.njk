{# Shared neobrutalist footer — only nav surface on the site. #}
<footer class="big-footer">
  <div class="big-footer-inner">
    <p class="footer-marquee">aesv<span class="accent">·</span>io <span class="footer-logo" aria-hidden="true"></span></p>

    <nav class="footer-row footer-row-pages" aria-label="Site pages">
      <h4>Pages</h4>
      <ul>
        <li>{% if route == '/' %}<span aria-current="page">aesv.io</span>{% else %}<a href="/">aesv.io</a>{% endif %}</li>
        <li>{% if route == '/work' or (route and route.startsWith('/work/')) %}<span aria-current="page">work</span>{% else %}<a href="/work">work</a>{% endif %}</li>
        <li>{% if route == '/music' %}<span aria-current="page">music</span>{% else %}<a href="/music">music</a>{% endif %}</li>
        <li>{% if route == '/activities' %}<span aria-current="page">activities</span>{% else %}<a href="/activities">activities</a>{% endif %}</li>
        <li>{% if route and route.startsWith('/garden') %}<span aria-current="page">files</span>{% else %}<a href="/garden">files</a>{% endif %}</li>
        <li>{% if route == '/about' %}<span aria-current="page">about</span>{% else %}<a href="/about">about</a>{% endif %}</li>
      </ul>
    </nav>

    <div class="footer-row footer-row-reach">
      <h4>Reach me</h4>
      <ul class="footer-icon-list">
          <li>
            <a href="mailto:mail@aesv.io" aria-label="Email mail@aesv.io">
              <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="5" width="18" height="14" rx="0"/>
                <path d="M3 7l9 6 9-6"/>
              </svg>
              <span>mail@aesv.io</span>
            </a>
          </li>
          <li>
            <a href="https://github.com/4esv" rel="noopener" aria-label="GitHub">
              <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
                <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.55v-2.07c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.73-1.53-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.18.91-.25 1.89-.38 2.86-.39.97.01 1.95.14 2.86.39 2.18-1.49 3.14-1.18 3.14-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.66.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
              </svg>
              <span>github.com/4esv</span>
            </a>
          </li>
          <li>
            <a href="https://linkedin.com/in/aesv" rel="noopener" aria-label="LinkedIn">
              <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
                <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 11-.01-4.12 2.06 2.06 0 010 4.12zM7.12 20.45H3.56V9h3.56v11.45z"/>
              </svg>
              <span>LinkedIn</span>
            </a>
          </li>
          <li>
            <a href="/api/gpg" aria-label="GPG public key">
              <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="8" cy="14" r="4"/>
                <path d="M11 12l9-9"/>
                <path d="M17 6l3 3"/>
                <path d="M14 9l3 3"/>
              </svg>
              <span>GPG public key</span>
            </a>
          </li>
        </ul>
    </div>

    <div class="footer-bottom">
      <span>© {{ now | date('Y') }} Axel Stevens · MIT</span>
    </div>
  </div>
</footer>
