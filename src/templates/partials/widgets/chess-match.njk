<div class="widget widget-chess">
  <div class="widget-art">
    {% if chess and chess.svg %}
      {{ chess.svg | safe }}
    {% else %}
      <div class="widget-spotify"><div class="placeholder" style="display:flex;align-items:center;justify-content:center;height:100%;color:#F4ECD8;font-family:ui-monospace,monospace;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;">no game</div></div>
    {% endif %}
  </div>
  <div class="widget-caption">
    {% if chess %}
      <div>
        <strong>{{ chess.white }} vs {{ chess.black }}</strong>
        <span class="meta">last victory · chess.com</span>
      </div>
      <span class="result">{{ chess.result }}</span>
    {% else %}
      <div><span class="meta">last victory · chess.com</span></div>
    {% endif %}
  </div>
</div>
