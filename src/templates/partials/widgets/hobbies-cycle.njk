{# Cycles between two visual states ~every 14s via dashboard.js.
   Both panes always present in the DOM; only opacity + visibility change. #}
<div class="widget widget-hobbies" data-cycle-interval="14000">
  <div class="hobby-pane is-active" data-pane="chess">
    {% if chess and chess.svg %}
      {{ chess.svg | safe }}
    {% else %}
      <div class="hobby-empty">no game</div>
    {% endif %}
  </div>

  <div class="hobby-pane" data-pane="strava">
    {% if strava and strava.routePath %}
      {% include "partials/widgets/strava-route.njk" %}
    {% elif strava %}
      <div class="hobby-strava-stats">
        <p class="strava-name">{{ strava.name }}</p>
        {% include "partials/widgets/strava-stats.njk" %}
      </div>
    {% else %}
      <div class="hobby-empty">no activity</div>
    {% endif %}
  </div>
</div>
