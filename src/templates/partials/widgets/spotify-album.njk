{# Music widget — album art of the top track (short term).
   Updates roughly weekly via the Spotify "short_term" window.
   The wrapping <a> + .cell-hover-label live in home.njk so the
   hover/press interactions match every other tile. #}
<div class="widget widget-spotify">
  <div class="widget-art">
    {% if topShort and topShort.album.artUrl %}
      <img src="{{ topShort.album.artUrl }}" alt="Album art for {{ topShort.album.name }} by {{ topShort.artist }}" loading="lazy">
    {% else %}
      <div class="widget-spotify-empty">no signal</div>
    {% endif %}
  </div>
</div>
