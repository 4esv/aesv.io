{# Shared header for the cream-paper system (home, work, garden,
   chess). Pages pass `pageEyebrow` to print a right-aligned label
   matching the bento page's "Axel Stevens" greeting position. #}
<header class="site-header">
  <a class="brand" href="/" aria-label="aesv.io home">
    <img src="/logo.png" alt="" width="36" height="36">
    <span>aesv.io</span>
  </a>
  <nav class="site-nav" aria-label="Primary">
    <a href="/work"{% if route == '/work' %} aria-current="page"{% endif %}>work</a>
    <a href="/garden"{% if route and route.startsWith('/garden') %} aria-current="page"{% endif %}>garden</a>
    <a href="/chess"{% if route == '/chess' %} aria-current="page"{% endif %}>chess</a>
    <a href="/listening"{% if route == '/listening' %} aria-current="page"{% endif %}>listening</a>
  </nav>
  {% if pageEyebrow %}<p class="dashboard-greeting"><strong>{{ pageEyebrow }}</strong></p>{% else %}<p class="dashboard-greeting"><strong>Axel Stevens</strong></p>{% endif %}
</header>
