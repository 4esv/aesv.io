{# Shared header — brand on the left, page-aware right slot.
   Home (route='/' or no route): greeting "Axel Stevens".
   Every subpage: "← back" link to the dashboard.
   Nav lives in the footer only — no top-of-page nav anywhere. #}
<header class="site-header">
  <a class="brand" href="/" aria-label="aesv.io home">
    <img src="/logo.png" alt="" width="36" height="36">
    <span>aesv.io</span>
  </a>
  {% if route and route != '/' %}
    <a class="back-link" href="/" aria-label="Back to the dashboard">← back</a>
  {% else %}
    <p class="dashboard-greeting"><strong>{{ pageEyebrow or 'Axel Stevens' }}</strong></p>
  {% endif %}
</header>
