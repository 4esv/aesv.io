<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ essay.title }} — garden · aesv.io</title>
  <meta name="description" content="{{ essay.summary or 'Entry in Axel Stevens\' garden.' }}">
  <link rel="icon" href="/logo-pixel.png" type="image/png">
  <link rel="apple-touch-icon" href="/logo.png">
  <meta name="theme-color" content="#F4ECD8">
  <link rel="preload" href="/fonts/birdie-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/katex.min.css">
  <link rel="stylesheet" href="/css/highlight.css">
  <link rel="stylesheet" href="/css/grdn.css">
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <main id="main" class="grdn-shell essay">
    {% set route = '/garden' %}
    {% set pageEyebrow = 'garden / ' + essay.title %}
    {% include "partials/site-header.njk" %}

    <header class="essay-header">
      <div class="essay-meta">
        {% if essay.date %}<time>{{ essay.date }}</time>{% endif %}
        {% for tag in essay.tags %}<span class="tag">{{ tag }}</span>{% endfor %}
      </div>
      <h1>{{ essay.title }}</h1>
      {% if essay.summary %}<p class="lede">{{ essay.summary }}</p>{% endif %}
    </header>

    <article class="prose">
      {{ html | safe }}
    </article>

    <nav class="essay-end">
      <a href="{{ basePath }}">← back to the garden</a>
    </nav>
  </main>

  {% include "partials/big-footer.njk" %}
</body>
</html>
