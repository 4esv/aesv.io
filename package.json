{
  "name": "aesv-io",
  "version": "1.0.0",
  "description": "Personal website for Axel Stevens — pretext-powered typographic layout",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "build:client": "esbuild src/client/main.js --bundle --outfile=src/static/js/bundle.js --format=esm --platform=browser --target=es2020",
    "build:client:watch": "esbuild src/client/main.js --bundle --outfile=src/static/js/bundle.js --format=esm --platform=browser --target=es2020 --watch",
    "dev": "npm run build:client && concurrently \"npm run build:client:watch\" \"node --env-file=.env --watch src/server.js\"",
    "dev:server": "node --env-file=.env --watch src/server.js",
    "start": "npm run build:client && node --env-file=.env src/server.js",
    "test": "node --test 'test/**/*.test.js'",
    "test:watch": "node --test --watch 'test/**/*.test.js'",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@fastify/static": "^8.0.0",
    "@fastify/view": "^10.0.0",
    "chess.js": "^1.4.0",
    "fastify": "^5.0.0",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT"
}
